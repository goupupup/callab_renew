# Copy to backend/.env or project-root .env for local development.
# Do not commit real credentials.

CALLAB_ORACLE_USER=
CALLAB_ORACLE_PASSWORD=
CALLAB_ORACLE_DSN=(DESCRIPTION=(TRANSPORT_CONNECT_TIMEOUT=5)(CONNECT_TIMEOUT=10)(RETRY_COUNT=0)(ADDRESS=(PROTOCOL=TCP)(HOST=172.20.25.2)(PORT=1521))(CONNECT_DATA=(SID=XE)))

# macOS Apple Silicon local test with Rosetta/x64 Oracle 19 client:
# CALLAB_ORACLE_LIB_DIR=/Users/victor/Develop/callab_renewal/.oracle/instantclient_19_20

# Windows Server production example:
# CALLAB_ORACLE_LIB_DIR=C:\oracle\instantclient_19_20

CALLAB_ORACLE_THICK_MODE=true
CALLAB_SESSION_SECRET=change-this
CALLAB_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

CALLAB_FTP_HOST=
CALLAB_FTP_USER=
CALLAB_FTP_PASSWORD=
